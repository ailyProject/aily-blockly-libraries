{
    "name": "@aily-project/lib-servo",
    "nickname": "舵机驱动",
    "author": "aily Project",
    "description": "方案描述：基于舵机驱动库，通过PWM信号精准控制舵机的转动角度，硬件连接简单，适配多种开发板。功能特点：支持多通道舵机控制、角度设定、速度调节，响应速度快，兼容多种舵机型号，适用于机器人、机械臂、智能控制等多种应用场景。",
    "version": "1.0.0",
    "compatibility": {
        "core": [
            "arduino:avr",
            "renesas_uno:minima",
            "renesas_uno:unor4wifi"
        ],
        "voltage": [
            3.3,
            5
        ]
    },
    "keywords": [
        "aily",
        "blockly",
        "servo",
        "servo_attach",
        "servo_write",
        "执行器"
    ],
    "scripts": {},
    "dependencies": {},
    "devDependencies": {},
    "tested": true,
    "tester": "mango-0616"
}
{
    "name": "@aily-project/lib-dht",
    "nickname": "DHT温湿度传感器",
    "author": "adafruit",
    "description": "方案描述：采用DHT系列温湿度传感器，通过单总线数字信号输出，实现环境温度与湿度的同步测量，硬件连接简便，适配多种开发板。功能特点：支持温湿度数据采集、低功耗运行、响应速度快、抗干扰能力强，兼容多种型号（如DHT11、DHT22）。",
    "version": "1.0.0",
    "compatibility": {
        "core": [
        ],
        "voltage": [
            3.3,
            5
        ]
    },
    "keywords": [
        "aily",
        "blockly",
        "sensor",
        "temperature",
        "humidity",
        "DHT11",
        "DHT22",
        "DHT21",
        "AM2302",
        "AM2301",
        "温度",
        "湿度",
        "传感器",
        "dht_init",
        "dht_read_temperature",
        "dht_read_humidity"
    ],
    "scripts": {},
    "dependencies": {},
    "devDependencies": {},
    "tested": true,
    "tester": "奈何col"
}
{
    "name": "@aily-project/lib-servo360",
    "nickname": "360舵机驱动",
    "author": "aily Project",
    "description": "基于360度舵机驱动库，通过PWM信号实现对360度连续旋转舵机的速度和方向控制，硬件连接简便，适配多种开发板。支持正反转、速度调节、停止控制，响应灵敏，兼容多种360度舵机，适用于小车驱动、机器人运动等多种应用场景。",
    "version": "1.0.0",
    "compatibility": {
        "core": [
            "arduino:avr",
            "renesas_uno:minima",
            "renesas_uno:unor4wifi"
        ],
        "voltage": [
            3.3,
            5
        ]
    },
    "keywords": [
        "aily",
        "blockly",
        "servo",
        "servo_attach",
        "servo_write",
        "执行器"
    ],
    "scripts": {},
    "dependencies": {},
    "devDependencies": {},
    "tested": true,
    "tester": "mango-0616"
}
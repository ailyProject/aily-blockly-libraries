{
  "kind": "category",
  "name": "Seeed RPC WiFi",
  "icon": "fa-light fa-wifi",
  "colour": "#00796B",
  "contents": [
    {
      "kind": "category",
      "name": "WiFi连接与状态",
      "icon": "fa-light fa-wifi",
      "colour": "#00796B",
      "contents": [
        { "kind": "block", "type": "seeed_rpcwifi_set_mode" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_begin",
          "inputs": {
            "SSID": { "shadow": { "type": "text", "fields": { "TEXT": "yourNetwork" } } },
            "PASSWORD": { "shadow": { "type": "text", "fields": { "TEXT": "yourPassword" } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_connect_wait",
          "inputs": {
            "SSID": { "shadow": { "type": "text", "fields": { "TEXT": "yourNetwork" } } },
            "PASSWORD": { "shadow": { "type": "text", "fields": { "TEXT": "yourPassword" } } },
            "TIMEOUT": { "shadow": { "type": "math_number", "fields": { "NUM": 15000 } } }
          }
        },
        { "kind": "block", "type": "seeed_rpcwifi_disconnect" },
        { "kind": "block", "type": "seeed_rpcwifi_reconnect" },
        { "kind": "block", "type": "seeed_rpcwifi_status" },
        { "kind": "block", "type": "seeed_rpcwifi_status_type" },
        { "kind": "block", "type": "seeed_rpcwifi_is_connected" },
        { "kind": "block", "type": "seeed_rpcwifi_wait_for_connect_result" },
        { "kind": "block", "type": "seeed_rpcwifi_local_ip" },
        { "kind": "block", "type": "seeed_rpcwifi_mac_address" },
        { "kind": "block", "type": "seeed_rpcwifi_current_ssid" },
        { "kind": "block", "type": "seeed_rpcwifi_rssi" },
        { "kind": "block", "type": "seeed_rpcwifi_set_auto_reconnect" },
        { "kind": "block", "type": "seeed_rpcwifi_mode_value" },
        { "kind": "block", "type": "seeed_rpcwifi_firmware_version" }
      ]
    },
    {
      "kind": "category",
      "name": "网络扫描",
      "icon": "fa-light fa-radar",
      "colour": "#0097A7",
      "contents": [
        { "kind": "block", "type": "seeed_rpcwifi_scan_networks" },
        { "kind": "block", "type": "seeed_rpcwifi_scan_complete" },
        { "kind": "block", "type": "seeed_rpcwifi_scan_delete" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_scanned_ssid",
          "inputs": { "INDEX": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } } }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_scanned_rssi",
          "inputs": { "INDEX": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } } }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_scanned_encryption",
          "inputs": { "INDEX": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } } }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_scanned_channel",
          "inputs": { "INDEX": { "shadow": { "type": "math_number", "fields": { "NUM": 0 } } } }
        },
        { "kind": "block", "type": "seeed_rpcwifi_encryption_type" }
      ]
    },
    {
      "kind": "category",
      "name": "WiFiMulti与热点",
      "icon": "fa-light fa-router",
      "colour": "#43A047",
      "contents": [
        { "kind": "label", "text": "WiFiMulti" },
        { "kind": "block", "type": "seeed_rpcwifi_multi_create" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_multi_add_ap",
          "inputs": {
            "SSID": { "shadow": { "type": "text", "fields": { "TEXT": "ssid_from_AP" } } },
            "PASSWORD": { "shadow": { "type": "text", "fields": { "TEXT": "your_password" } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_multi_run",
          "inputs": { "TIMEOUT": { "shadow": { "type": "math_number", "fields": { "NUM": 5000 } } } }
        },
        { "kind": "label", "text": "热点(AP)" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_softap",
          "inputs": {
            "SSID": { "shadow": { "type": "text", "fields": { "TEXT": "WioAP" } } },
            "PASSWORD": { "shadow": { "type": "text", "fields": { "TEXT": "12345678" } } },
            "CHANNEL": { "shadow": { "type": "math_number", "fields": { "NUM": 11 } } },
            "MAX_CONN": { "shadow": { "type": "math_number", "fields": { "NUM": 4 } } }
          }
        },
        { "kind": "block", "type": "seeed_rpcwifi_softap_config" },
        { "kind": "block", "type": "seeed_rpcwifi_softap_disconnect" },
        { "kind": "block", "type": "seeed_rpcwifi_softap_station_count" },
        { "kind": "block", "type": "seeed_rpcwifi_softap_ip" }
      ]
    },
    {
      "kind": "category",
      "name": "TCP客户端",
      "icon": "fa-light fa-network-wired",
      "colour": "#5E35B1",
      "contents": [
        { "kind": "block", "type": "seeed_rpcwifi_client_create" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_client_connect",
          "inputs": {
            "HOST": { "shadow": { "type": "text", "fields": { "TEXT": "www.example.com" } } },
            "PORT": { "shadow": { "type": "math_number", "fields": { "NUM": 80 } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_secure_set_ca",
          "inputs": { "CA_CERT": { "shadow": { "type": "text", "fields": { "TEXT": "-----BEGIN CERTIFICATE-----\\n...\\n-----END CERTIFICATE-----\\n" } } } }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_client_print",
          "inputs": { "DATA": { "shadow": { "type": "text", "fields": { "TEXT": "GET / HTTP/1.1" } } } }
        },
        { "kind": "block", "type": "seeed_rpcwifi_client_available" },
        { "kind": "block", "type": "seeed_rpcwifi_client_read_string" },
        { "kind": "block", "type": "seeed_rpcwifi_client_connected" },
        { "kind": "block", "type": "seeed_rpcwifi_client_stop" }
      ]
    },
    {
      "kind": "category",
      "name": "UDP通信",
      "icon": "fa-light fa-network-wired",
      "colour": "#3949AB",
      "contents": [
        { "kind": "block", "type": "seeed_rpcwifi_udp_create" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_udp_begin",
          "inputs": { "PORT": { "shadow": { "type": "math_number", "fields": { "NUM": 2390 } } } }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_udp_send",
          "inputs": {
            "HOST": { "shadow": { "type": "text", "fields": { "TEXT": "192.168.0.255" } } },
            "PORT": { "shadow": { "type": "math_number", "fields": { "NUM": 3333 } } },
            "DATA": { "shadow": { "type": "text", "fields": { "TEXT": "Hello UDP" } } }
          }
        },
        { "kind": "block", "type": "seeed_rpcwifi_udp_parse_packet" },
        { "kind": "block", "type": "seeed_rpcwifi_udp_read_string" }
      ]
    },
    {
      "kind": "category",
      "name": "HTTP/HTTPS",
      "icon": "fa-light fa-globe",
      "colour": "#EF6C00",
      "contents": [
        { "kind": "block", "type": "seeed_rpcwifi_http_create" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_http_begin",
          "inputs": { "URL": { "shadow": { "type": "text", "fields": { "TEXT": "http://www.example.com/index.html" } } } }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_http_begin_https",
          "inputs": {
            "URL": { "shadow": { "type": "text", "fields": { "TEXT": "https://www.example.com/index.html" } } },
            "CA_CERT": { "shadow": { "type": "text", "fields": { "TEXT": "-----BEGIN CERTIFICATE-----\\n...\\n-----END CERTIFICATE-----\\n" } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_http_add_header",
          "inputs": {
            "NAME": { "shadow": { "type": "text", "fields": { "TEXT": "Content-Type" } } },
            "VALUE": { "shadow": { "type": "text", "fields": { "TEXT": "text/plain" } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_http_request",
          "inputs": { "DATA": { "shadow": { "type": "text", "fields": { "TEXT": "Hello from Wio Terminal" } } } }
        },
        { "kind": "block", "type": "seeed_rpcwifi_http_get_string" },
        { "kind": "block", "type": "seeed_rpcwifi_http_end" }
      ]
    },
    {
      "kind": "category",
      "name": "WebServer",
      "icon": "fa-light fa-server",
      "colour": "#D84315",
      "contents": [
        { "kind": "block", "type": "seeed_rpcwifi_webserver_create" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_webserver_on",
          "inputs": { "PATH": { "shadow": { "type": "text", "fields": { "TEXT": "/" } } } }
        },
        { "kind": "block", "type": "seeed_rpcwifi_webserver_begin" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_webserver_send",
          "inputs": {
            "CODE": { "shadow": { "type": "math_number", "fields": { "NUM": 200 } } },
            "TYPE": { "shadow": { "type": "text", "fields": { "TEXT": "text/plain" } } },
            "CONTENT": { "shadow": { "type": "text", "fields": { "TEXT": "hello from Wio Terminal" } } }
          }
        },
        { "kind": "block", "type": "seeed_rpcwifi_webserver_handle_client" }
      ]
    },
    {
      "kind": "category",
      "name": "DNS与mDNS",
      "icon": "fa-light fa-globe",
      "colour": "#00897B",
      "contents": [
        { "kind": "label", "text": "DNS" },
        { "kind": "block", "type": "seeed_rpcwifi_dns_create" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_dns_start",
          "inputs": {
            "PORT": { "shadow": { "type": "math_number", "fields": { "NUM": 53 } } },
            "DOMAIN": { "shadow": { "type": "text", "fields": { "TEXT": "www.wioterminal.com" } } },
            "IP": { "shadow": { "type": "text", "fields": { "TEXT": "192.168.1.1" } } }
          }
        },
        { "kind": "block", "type": "seeed_rpcwifi_dns_start_captive" },
        { "kind": "block", "type": "seeed_rpcwifi_dns_process" },
        { "kind": "label", "text": "mDNS" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_mdns_begin",
          "inputs": { "HOSTNAME": { "shadow": { "type": "text", "fields": { "TEXT": "WioTerminal" } } } }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_mdns_add_service",
          "inputs": {
            "SERVICE": { "shadow": { "type": "text", "fields": { "TEXT": "http" } } },
            "PORT": { "shadow": { "type": "math_number", "fields": { "NUM": 80 } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_mdns_query_host",
          "inputs": {
            "HOST": { "shadow": { "type": "text", "fields": { "TEXT": "WioTerminal" } } },
            "TIMEOUT": { "shadow": { "type": "math_number", "fields": { "NUM": 2000 } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_mdns_query_service",
          "inputs": { "SERVICE": { "shadow": { "type": "text", "fields": { "TEXT": "http" } } } }
        }
      ]
    },
    {
      "kind": "category",
      "name": "WiFiManager配网",
      "icon": "fa-light fa-router",
      "colour": "#4CAF50",
      "contents": [
        { "kind": "block", "type": "seeed_rpcwifi_wifimanager_create" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_wifimanager_auto_connect",
          "inputs": {
            "AP_NAME": { "shadow": { "type": "text", "fields": { "TEXT": "AutoConnectAP" } } },
            "AP_PASSWORD": { "shadow": { "type": "text", "fields": { "TEXT": "" } } }
          }
        },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_wifimanager_start_portal",
          "inputs": {
            "AP_NAME": { "shadow": { "type": "text", "fields": { "TEXT": "ConfigPortal" } } },
            "AP_PASSWORD": { "shadow": { "type": "text", "fields": { "TEXT": "" } } }
          }
        },
        { "kind": "block", "type": "seeed_rpcwifi_wifimanager_reset" },
        {
          "kind": "block",
          "type": "seeed_rpcwifi_wifimanager_set_timeout",
          "inputs": { "SECONDS": { "shadow": { "type": "math_number", "fields": { "NUM": 120 } } } }
        },
        { "kind": "block", "type": "seeed_rpcwifi_wifimanager_get_info" }
      ]
    }
  ]
}
{
  "name": "@aily-project/lib-encoder",
  "nickname": "Arduino旋转编码器库",
  "author": "OpenJumper",
  "description": "基于Arduino旋转编码器库，通过数字引脚读取旋转编码器的脉冲信号，实现旋转方向与步进计数的精准检测，硬件连接简单，适配多种开发板。支持旋转方向识别、步数计数、按键检测（带按键编码器），响应速度快，兼容多种主流开发板。",
  "version": "0.0.1",
  "compatibility": {
      "core": [
        "arduino:avr"
      ],
      "voltage": [
          3.3,
          5
      ]
  },
  "keywords": [
      "aily",
      "blockly",
      "ArduinoEncoder",
      "旋转编码器",
      "编码器",
      "传感器"
  ],
  "scripts": {},
  "dependencies": {},
  "devDependencies": {},
  "tested": true,
  "tester": "openjumper"
}
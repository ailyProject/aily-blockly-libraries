{
  "toolbox_name": "DFRobot Electrochemical Oxygen",
  "dfrobot_eoxygen_sensor_init": {
    "message0": "initialize DFRobot Electrochemical Oxygen %1 I2C %2 address %3",
    "tooltip": "Create and initialize DFRobot Electrochemical Oxygen.",
    "args0": [
      null,
      {
        "options": "${board.i2c}"
      },
      {
        "options": [
          [
            "0x30",
            "0x30"
          ],
          [
            "0x31",
            "0x31"
          ],
          [
            "0x32",
            "0x32"
          ],
          [
            "0x33",
            "0x33"
          ]
        ]
      }
    ]
  },
  "dfrobot_eoxygen_sensor_read": {
    "message0": "DFRobot Electrochemical Oxygen %1 read %2",
    "tooltip": "Read a value from DFRobot Electrochemical Oxygen.",
    "args0": [
      null,
      {
        "options": [
          [
            "oxygen concentration (%vol)",
            "oxygen"
          ],
          [
            "calibration state",
            "calibration"
          ]
        ]
      }
    ]
  },
  "dfrobot_eoxygen_sensor_action": {
    "message0": "DFRobot Electrochemical Oxygen %1 operation %2",
    "tooltip": "Run an operation on DFRobot Electrochemical Oxygen.",
    "args0": [
      null,
      {
        "options": [
          [
            "calibrate at 20.9%",
            "calibrate_air"
          ],
          [
            "calibrate at 99.5%",
            "calibrate_high"
          ],
          [
            "clear calibration",
            "clear"
          ]
        ]
      }
    ]
  }

      null,
      {
        "options": "${board.i2c}"
      },
      {
        "options": [
          [
            "0x33",
            "0x33"
          ]
        ]
      }
    ]
  },
  "adafruit_mlx90640_read": {
    "message0": "Adafruit MLX90640 %1 read %2 pixel (0-767) %3",


{
    "name": "@aily-project/lib-iicmotordriver",
    "nickname": "IIC电机驱动库",
    "author": "K2L",
    "description": "方案描述：硬件匹配openjumper IIC-MS驱动板，基于I²C协议的电机驱动模块，通过两线通信实现对直流电机或步进电机的精准控制，极大简化硬件连线。功能特点：支持多路电机独立控制、转速调节、正反转切换、刹车功能，兼容多种主流开发板。",
    "version": "0.0.1",
    "compatibility": {
        "core": [
            "arduino:avr",
            "esp32:esp32"
        ],
        "voltage": [3.3, 5]
    },
    "keywords": [
        "aily",
        "blockly",
        "iic",
        "motordriver",
        "电机驱动",
        "电机"
    ],
    "scripts": {},
    "dependencies": {},
    "devDependencies": {},
    "tested": true,
    "tester": "K2L"
}

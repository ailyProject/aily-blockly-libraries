        {"kind": "block", "type": "ha_mqtt_on_message"},
        {"kind": "block", "type": "ha_mqtt_message_topic"},
        {"kind": "block", "type": "ha_mqtt_message_payload"},
        {"kind": "block", "type": "ha_mqtt_message_length"}

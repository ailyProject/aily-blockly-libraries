        {
          "kind": "block",
          "type": "ha_mqtt_set_buffer_size",
          "inputs": {"SIZE": {"shadow": {"type": "math_number", "fields": {"NUM": 512}}}}
        },
        {"kind": "block", "type": "ha_mqtt_loop"},
        {"kind": "block", "type": "ha_mqtt_connected"},
        {"kind": "block", "type": "ha_mqtt_state"},
        {"kind": "block", "type": "ha_mqtt_disconnect"}
      ]
    },

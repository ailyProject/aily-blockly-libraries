        {"kind": "block", "type": "ha_device_set_info"},
        {"kind": "block", "type": "ha_device_enable_availability"},
        {"kind": "block", "type": "ha_mqtt_create"},
        {
          "kind": "block",
          "type": "ha_mqtt_begin",
          "inputs": {
            "HOST": {"shadow": {"type": "text", "fields": {"TEXT": "homeassistant.local"}}},
            "PORT": {"shadow": {"type": "math_number", "fields": {"NUM": 1883}}},
            "USERNAME": {"shadow": {"type": "text", "fields": {"TEXT": ""}}},
            "PASSWORD": {"shadow": {"type": "text", "fields": {"TEXT": ""}}}
          }
        },
        {"kind": "block", "type": "ha_mqtt_set_prefixes"},

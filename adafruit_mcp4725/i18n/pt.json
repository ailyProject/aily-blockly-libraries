{
  "toolbox_name": "Adafruit MCP4725",
  "adafruit_mcp4725_init": {
    "message0": "initialize Adafruit MCP4725 %1 I2C %2 address %3",
    "tooltip": "Create and initialize Adafruit MCP4725.",
    "args0": [
      null,

          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 3
            }
          }
        },
        "DOWN_PIN": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 18
            }
          }
        },
        "ENTER_PIN": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 8
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "miaoui_set_debounce",
      "inputs": {
        "MILLISECONDS": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 35
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "miaoui_set_button_repeat",

    },
    {
      "kind": "block",
      "type": "miaoui_add_page"
    },
    {
      "kind": "block",
      "type": "miaoui_add_item"
    },
    {
      "kind": "block",
      "type": "miaoui_add_navigation_item"
    },
    {
      "kind": "block",
      "type": "miaoui_add_action_item"
    },
    {
      "kind": "label",
      "text": "数据与文本绑定（放入初始化块）"
    },
    {
      "kind": "block",
      "type": "miaoui_bind_number",
      "inputs": {
        "INITIAL": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 50
            }
          }
        },
        "MIN": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 0
            }
          }
        },
        "MAX": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 100
            }
          }
        },
        "STEP": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 5
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "miaoui_bind_switch",
      "inputs": {
        "INITIAL": {
          "shadow": {
            "type": "logic_boolean",
            "fields": {
              "BOOL": "TRUE"
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "miaoui_bind_text"
    },
    {
      "kind": "label",
      "text": "运行与外部输入"
    },
    {
      "kind": "block",
      "type": "miaoui_push_action"
    },
    {
      "kind": "block",
      "type": "miaoui_try_push_action"
    },
    {
      "kind": "block",
      "type": "miaoui_update"
    },
    {
      "kind": "block",
      "type": "miaoui_set_background",
      "inputs": {
        "INVERTED": {
          "shadow": {
            "type": "logic_boolean",
            "fields": {
              "BOOL": "FALSE"
            }
          }
        }
      }
    },
    {
      "kind": "label",
      "text": "状态"
    },
    {
      "kind": "block",
      "type": "miaoui_is_begun"
    },
    {
      "kind": "block",
      "type": "miaoui_last_error_code"
    },
    {
      "kind": "block",
      "type": "miaoui_last_error_message"
    },
    {
      "kind": "block",
      "type": "miaoui_current_item_name"

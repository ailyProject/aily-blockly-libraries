{
  "toolbox_name": "Adafruit MAX31856",
  "adafruit_max31856_init": {
    "message0": "initialize Adafruit MAX31856 %1 CS pin %2",
    "tooltip": "Create and initialize Adafruit MAX31856.",
    "args0": [
      null,
      {
        "options": "${board.digitalPin}"
      }
    ]
  },
  "adafruit_max31856_read": {
    "message0": "Adafruit MAX31856 %1 read %2",
    "tooltip": "Read a value from Adafruit MAX31856.",
    "args0": [
      null,
      {
        "options": [
          [
            "thermocouple (C)",
            "thermocouple"
          ],
          [
            "cold junction (C)",
            "cold_junction"
          ],
          [
            "fault bits",
            "fault"
          ]
        ]
      }
    ]
  },
  "adafruit_max31856_set": {
    "message0": "Adafruit MAX31856 %1 set %2 value %3",
    "tooltip": "Configure Adafruit MAX31856.",
    "args0": [
      null,
      {
        "options": [
          [
            "thermocouple type enum (0-7)",
            "type"
          ],
          [
            "conversion mode (0 one-shot, 1 continuous)",
            "mode"
          ]
        ]
      },
      null
    ]
  }
}

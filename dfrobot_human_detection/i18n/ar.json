{
  "toolbox_name": "DFRobot Human Detection",
  "dfrobot_human_detection_init": {
    "message0": "initialize DFRobot Human Detection %1 serial port %2",
    "tooltip": "Create and initialize DFRobot Human Detection.",
    "args0": [
      null,
      {
        "options": "${board.serialPort}"
      }
    ]
  },
  "dfrobot_human_detection_read": {
    "message0": "DFRobot Human Detection %1 read %2",
    "tooltip": "Read a value from DFRobot Human Detection.",
    "args0": [
      null,
      {
        "options": [
          [
            "human presence",
            "presence"
          ],
          [
            "movement state",
            "movement"
          ],
          [
            "movement range",
            "range"
          ],
          [
            "human distance",
            "distance"
          ],
          [
            "heart rate",
            "heart_rate"
          ],
          [
            "breathing rate",
            "breathing"
          ],
          [
            "work mode",
            "mode"
          ]
        ]
      }
    ]
  },
  "dfrobot_human_detection_action": {
    "message0": "DFRobot Human Detection %1 operation %2",
    "tooltip": "Run an operation on DFRobot Human Detection.",
    "args0": [
      null,
      {
        "options": [
          [
            "sleep monitoring mode",
            "sleep_mode"
          ],
          [
            "fall detection mode",
            "fall_mode"
          ]
        ]
      }
    ]
  }
}

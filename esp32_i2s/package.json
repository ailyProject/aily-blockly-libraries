{
  "name": "@aily-project/lib-esp32-i2s",
  "nickname": "ESP32 I2S音频库",
  "author": "aily Project",
  "description": "基于ESP32 I2S音频库，利用ESP32内置I2S硬件接口，实现高质量音频数据的采集与播放，支持多种音频编解码芯片，简化音频应用开发流程。支持音频录制与回放、立体声/单声道切换、采样率和位宽可调，兼容多种音频外设，低延迟高性能。",
  "version": "1.0.0",
  "compatibility": {
    "core": [
      "esp32:esp32",
      "esp32:esp32s3"
    ],
    "voltage": [3.3]
  },
  "keywords": [
    "esp32-i2s",
    "音频功放",
    "WAV文件",
    "音频录制",
    "音频播放",
    "音调生成",
    "旋律播放",
    "I2S",
    "音频处理",
    "音频库",
    "音频输入",
    "音频输出",
    "音频采集",
    "音频播放器",
    "数字麦克风",
    "I2S麦克风",
    "麦克风",
    "audio",
    "microphone",
    "speaker"
  ],
  "scripts": {},
  "dependencies": {},
  "devDependencies": {},
  "tested": true,
  "tester": "openjumper"
}
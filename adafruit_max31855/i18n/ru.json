{
  "toolbox_name": "Adafruit MAX31855",
  "adafruit_max31855_init": {
    "message0": "initialize Adafruit MAX31855 %1 CS pin %2",
    "tooltip": "Create and initialize Adafruit MAX31855.",
    "args0": [
      null,
      {
        "options": "${board.digitalPin}"
      }
    ]
  },
  "adafruit_max31855_read": {
    "message0": "Adafruit MAX31855 %1 read %2",
    "tooltip": "Read a value from Adafruit MAX31855.",
    "args0": [
      null,
      {
        "options": [
          [
            "thermocouple (C)",
            "thermocouple_c"
          ],
          [
            "thermocouple (F)",
            "thermocouple_f"
          ],
          [
            "cold junction (C)",
            "internal"
          ],
          [
            "fault bits",
            "error"
          ]
        ]
      }
    ]
  }
}

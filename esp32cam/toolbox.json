{
  "kind": "category",
  "name": "ESP32Cam 摄像头",
  "icon": "fa-light fa-camera",
  "colour": "#1565C0",
  "contents": [
    {
      "kind": "label",
      "text": "初始化"
    },
    {
      "kind": "block",
      "type": "esp32cam_init",
      "fields": {
        "PINS": "AUTO",
        "RESOLUTION": "320,240",
        "FORMAT": "JPEG"
      },
      "inputs": {
        "QUALITY": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 80
            }
          }
        },
        "BUFFER_COUNT": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 2
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "esp32cam_is_ready"
    },
    {
      "kind": "block",
      "type": "esp32cam_set_logger"
    },
    {
      "kind": "block",
      "type": "esp32cam_end"
    },
    {
      "kind": "label",
      "text": "运行时设置"
    },
    {
      "kind": "block",
      "type": "esp32cam_update_resolution"
    },
    {
      "kind": "block",
      "type": "esp32cam_update_image",
      "inputs": {
        "BRIGHTNESS": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 0
            }
          }
        },
        "CONTRAST": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 0
            }
          }
        },
        "SATURATION": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 0
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "esp32cam_update_gain",
      "inputs": {
        "GAIN": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": -2
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "esp32cam_update_light_mode"
    },
    {
      "kind": "block",
      "type": "esp32cam_update_special_effect"
    },
    {
      "kind": "block",
      "type": "esp32cam_update_flip"
    },
    {
      "kind": "block",
      "type": "esp32cam_update_corrections"
    },
    {
      "kind": "block",
      "type": "esp32cam_status_number"
    },
    {
      "kind": "block",
      "type": "esp32cam_status_boolean"
    },
    {
      "kind": "label",
      "text": "图像帧"
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_create",
      "fields": {
        "VAR": "frame"
      }
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_capture"
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_available"
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_info"
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_format_is"
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_convert",
      "inputs": {
        "QUALITY": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 80
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_write_serial",
      "inputs": {
        "TIMEOUT": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 10000
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "esp32cam_frame_release"
    },
    {
      "kind": "label",
      "text": "WebServer 集成"
    },
    {
      "kind": "block",
      "type": "esp32cam_webserver_send_frame",
      "inputs": {
        "TIMEOUT": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 10000
            }
          }
        }
      }
    },
    {
      "kind": "block",
      "type": "esp32cam_webserver_stream_mjpeg",
      "inputs": {
        "MIN_INTERVAL": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 0
            }
          }
        },
        "MAX_FRAMES": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": -1
            }
          }
        },
        "FRAME_TIMEOUT": {
          "shadow": {
            "type": "math_number",
            "fields": {
              "NUM": 10000
            }
          }
        }
      }
    }

{
  "name": "@aily-project/lib-u8g2",
  "nickname": "单色显示屏",
  "author": "奈何col",
  "description": "基于U8G2显示屏库，支持多种单色OLED和LCD显示屏，通过I²C、SPI等接口实现图形和文本的高效显示，适配多种开发板。支持多种分辨率和显示器类型，丰富的图形绘制和字体显示功能，接口简单，适用于仪表盘、信息显示等场景。",
  "version": "1.0.0",
  "compatibility": {
    "core": [],
    "voltage": [
      3.3,
      5
    ]
  },
  "keywords": [
    "aily",
    "blockly",
    "display",
    "u8g2",
    "oled",
    "lcd",
    "12864",
    "ssd1306",
    "sh1106",
    "st7920",
    "显示屏",
    "图形",
    "点阵显示屏"
  ],
  "scripts": {},
  "dependencies": {},
  "devDependencies": {},
  "tested": true,
  "tester": "mango"
}
{
  "toolbox_name": "文字轉語音",
  "openjumper_tts_init": {
    "message0": "TTS初始化 RX腳位：%1 TX腳位：%2",
    "args0": [
      {
        "options": "${board.digitalPins}"
      },
      {
        "options": "${board.digitalPins}"
      }
    ],
    "tooltip": "初始化OpenJumper TTS語音合成模組，設定軟串口通訊腳"
  },
  "openjumper_tts_play_invoice": {
    "message0": "播放內建 %1 第%2首",
    "args0": [
      {
        "options": [
          [
            "鈴聲",
            "VOICE_Ringtones"
          ],
          [
            "通知音",
            "VOICE_PromptSound"
          ],
          [
            "警告聲",
            "VOICE_WarningSound"
          ]
        ]
      },
      null
    ],
    "tooltip": "播放TTS模組內建的鈴聲、提示音或警示音"
  },
  "openjumper_tts_play_control": {
    "message0": "控製播放 %1",
    "args0": [
      {
        "options": [
          [
            "停下",
            "PLAY_STOP"
          ],
          [
            "暫停",
            "PLAY_PAUSE"
          ],
          [
            "繼續",
            "PLAY_CONTINUE"
          ]
        ]
      }
    ],
    "tooltip": "控制TTS播放狀態：停止、暫停或繼續播放"
  },
  "openjumper_tts_play_number": {
    "message0": "播放數字 %1",
    "args0": [
      null
    ],
    "tooltip": "將數位轉換為語音播報"
  },
  "openjumper_tts_play_text": {
    "message0": "播放文字 %1",
    "args0": [
      null
    ],
    "tooltip": "將文字內容轉換為語音播報，支援中文和數字"
  },
  "openjumper_tts_setcfg": {
    "message0": "設定%1 為%2",
    "args0": [
      {
        "options": [
          [
            "語速",
            "setspeechSpeed"
          ],
          [
            "語調",
            "setIntonation"
          ],
          [
            "音量",
            "setVolume"
          ]
        ]
      },
      null
    ],
    "tooltip": "設定TTS語音參數：語速(0-10)、語調(0-10)或音量(0-10)"
  },
  "openjumper_tts_restore_defaults": {
    "message0": "恢復預設設定",
    "tooltip": "將語速、語調、音量恢復到預設值"
  }
}

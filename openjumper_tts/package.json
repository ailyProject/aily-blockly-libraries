{
    "name": "@aily-project/lib-tts",
    "nickname": "TTS语音合成模块",
    "author": "OpenJumper",
    "description": "适配openjumperTTS语音合成模块（编号ojmoBhp4035 ），通过串口或I²C等接口将文本内容实时转换为语音输出，简化语音播报功能的实现，适配多种开发板。支持多语言文本合成、语速与音量调节、发音清晰自然，接口简单易用，适用于语音提示、智能交互等多种应用场景。",
    "version": "0.0.1",
    "compatibility": {
        "core": [],
        "voltage": [
            3.3,
            5
        ]
    },
    "keywords": [
        "aily",
        "blockly",
        "tts",
        "text-to-speech",
        "openjumpert",
        "artificial intelligence"
    ],
    "scripts": {},
    "dependencies": {},
    "devDependencies": {},
    "tested": true,
    "tester": "K2L"
}
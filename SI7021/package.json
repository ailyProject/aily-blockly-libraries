{
  "name": "@aily-project/lib-si7021",
  "nickname": "Si7021温湿度传感器",
  "author": "aily Project",
  "description": "采用Si7021温湿度传感器，通过I²C接口实现环境温度与湿度的高精度测量，硬件连接简便，适配多种开发板。支持温湿度同步采集，响应速度快，低功耗，兼容多平台，适用于环境监测、智能家居等场景。",
  "version": "1.0.0",
  "compatibility": {
     "core": [
            "arduino:avr",
            "esp32:esp32",
            "esp32:esp32c3",
            "esp32:esp32s3"
        ],
    "voltage": [3.3, 5]
  },
  "keywords": [
    "aily",
    "blockly",
    "si7021",
    "temperature",
    "humidity",
    "sensor",
    "温度",
    "湿度",
    "传感器"
  ],
  "scripts": {},
  "dependencies": {},
  "devDependencies": {},
  "tested": true,                    
  "tester": "openjumper"  
}
